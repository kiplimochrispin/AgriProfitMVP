{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "noEmitOnError": true,
    "rootDir": "src/frontend",
    "outDir": "static",
    "skipLibCheck": true
  },
  "include": ["src/frontend/**/*.ts"]
}
